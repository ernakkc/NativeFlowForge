{
  "name": "nativeflowforge",
  "version": "1.0.0",
  "description": "Desktop-based local workflow automation tool",
  "homepage": "https://github.com/ernakkc/NativeFlowForge#readme",
  "bugs": {
    "url": "https://github.com/ernakkc/NativeFlowForge/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ernakkc/NativeFlowForge.git"
  },
  "keywords": [
    "electron",
    "vite",
    "react",
    "workflow",
    "automation",
    "typescript"
  ],
  "license": "MIT",
  "author": "",
  "type": "module",
  "main": "dist/electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "@xyflow/react": "^12.10.1",
    "drizzle-orm": "^0.29.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "sqlite3": "^6.0.1",
    "vite-plugin-electron": "^0.29.1",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  },
  "build": {
    "appId": "com.nativeflowforge.app",
    "productName": "NativeFlowForge",
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "assets"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    },
    "win": {
      "target": "nsis"
    }
  }
}